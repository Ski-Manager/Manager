<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve ads.txt directly – required by the IAB ads.txt standard.
    RewriteRule ^ads\.txt$ - [L]

    # Serve .well-known/* directly (TWA asset links, ACME challenges, etc.)
    RewriteRule ^\.well-known/ - [L]

    # Serve manifest.json directly (PWA web app manifest)
    RewriteRule ^manifest\.json$ - [L]

    # Canonical redirect: enforce https://www in a single hop.
    # Localhost and loopback addresses are exempt so local development still works.
    #
    # Rule A – direct HTTPS access to non-www (Cloudflare bypass scenario).
    RewriteCond %{HTTPS} on
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteCond %{HTTP_HOST} !^localhost(:[0-9]+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:[0-9]+)?$ [NC]
    RewriteRule ^(.*)$ https://www.ski-manager.net%{REQUEST_URI} [L,R=301]
    #
    # Rule B – any HTTP request (direct or via Cloudflare) or non-www HTTPS via proxy.
    # Logic: (HTTPS=off) AND (HOST is not localhost) AND (X-Forwarded-Proto!=https OR Host is not www)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost(:[0-9]+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:[0-9]+)?$ [NC]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://www.ski-manager.net%{REQUEST_URI} [L,R=301]

    # 404 Error Document (Added)
    ErrorDocument 404 /404.html

    # Pass Authorization header to environment variable
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Skip /cdn-cgi/ paths (handled by Cloudflare, not CodeIgniter)
    RewriteRule ^cdn-cgi/ - [L]

    # Remove trailing slashes from URLs (except root) to avoid duplicate 404s
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # Rewrite rules for CodeIgniter (or similar framework)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?/$1 [L,QSA]

</IfModule>

# HSTS: instruct browsers to always use HTTPS for this domain (1 year).
# The condition also covers requests arriving via a TLS-terminating proxy
# (e.g. Cloudflare), where the origin server sees HTTPS=off but the
# X-Forwarded-Proto header is set to "https".
<If "%{HTTPS} == 'on' || %{HTTP:X-Forwarded-Proto} == 'https'">
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</If>

# Opt out of FLEDGE / Protected Audience API to suppress the
# "Deprecation / Fledge" warning produced by Google Ads scripts.
Header always set Permissions-Policy "join-ad-interest-group=(), run-ad-auction=()"

# Enable Brotli compression for text-based assets (preferred over gzip when supported)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Enable gzip compression for text-based assets (fallback when Brotli is unavailable)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Cache static assets: images and fonts for 1 year, CSS/JS for 1 year
<FilesMatch "\.(avif|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
    Header unset Expires
</FilesMatch>

<FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
    Header unset Expires
</FilesMatch>

# No caching for dynamic PHP and HTML pages
<FilesMatch "\.(html|htm|php)$">
    FileETag None
    Header unset ETag
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
</FilesMatch>

# Block direct HTTP access to development draft images that are not used in production
<IfModule mod_rewrite.c>
    RewriteRule ^img/images/local_drafts/ - [F,L]
</IfModule>

# Set CodeIgniter environment (optional, but good practice)
SetEnv CI_ENV development

# Remove X-Powered-By header to avoid exposing server technology
Header unset X-Powered-By
Header always unset X-Powered-By
