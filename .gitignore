# =============================================================================
# Ski Manager — .gitignore
# Stack: CodeIgniter 3, PHP, MySQL, Redis, Apache, GitHub Actions → VPS
# =============================================================================

# =============================================================================
# Environment & Secrets
# NEVER commit credentials, keys, or environment-specific config
# =============================================================================
.env
.env.*
application/config/database.php
application/config/email.php
application/config/google.php
application/config/facebook.php
application/config/paypal.php
application/config/memcached.php

# =============================================================================
# CodeIgniter Runtime
# =============================================================================
application/logs/*.log
application/cache/*
application/cache/
!application/cache/.htaccess
!application/cache/index.html
application/sessions/

# =============================================================================
# Uploads & User-Generated Content
# =============================================================================
uploads/
application/uploads/
storage/

# =============================================================================
# Database Backups (generated by NightlyDBBackup_controller)
# =============================================================================
backups/
*.sql
*.sql.gz

# =============================================================================
# SSL / TLS Certificates
# =============================================================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# =============================================================================
# PHP Dependencies (if Composer is used)
# =============================================================================
vendor/
composer.lock

# =============================================================================
# Node / Frontend Build (if used for assets)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
public/build/

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS-Specific
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.nfs*

# =============================================================================
# Archives & Generated Bundles
# =============================================================================
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tgz
*.rar
*.7z

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# Cache & Temp
# =============================================================================
.cache/
.tmp/
.temp/
tmp/

# =============================================================================
# Docker (local dev volumes)
# =============================================================================
docker-data/
volumes/
.docker/

# =============================================================================
# Testing & Coverage
# =============================================================================
coverage/
.nyc_output/
phpunit.xml
.phpunit.result.cache

# =============================================================================
# Miscellaneous
# =============================================================================
*.pid
*.seed
*.pid.lock
pids/
